generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id                Int           @id @default(autoincrement())
  date              String        // "2026-03-21"
  startTime         String        // "10:00"
  endTime           String        // "12:00"
  location          String
  description       String?
  isOpen            Boolean       @default(true)
  settlementOpen    Boolean       @default(false)
  meetingType       String        @default("정기") // 정기 | 비정기
  createdByKakaoId  String?       // null = admin, otherwise member's kakaoId
  participants      Participant[]
  foodOrderItems    ParticipantFoodOrderItem[]
  foodOrders        ParticipantFoodOrder[]
  chargeAdjustments ParticipantChargeAdjustment[]
  settlementConfirmations SettlementConfirmation[]
  createdAt         DateTime      @default(now())
}

model Participant {
  id               Int        @id @default(autoincrement())
  meetingId        Int
  meeting          Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name             String
  kakaoId          String
  user             User?      @relation(fields: [kakaoId], references: [kakaoId])
  kakaoNickname    String     // 카카오 프로필 닉네임 (참고용)
  companionId      Int?       // 동반인인 경우 Companion.id
  companion        Companion? @relation(fields: [companionId], references: [id])
  note             String?
  hasLesson        Boolean    @default(false) // 강습 여부
  hasBus           Boolean    @default(false) // 버스 이용 여부
  hasRental        Boolean    @default(false) // 장비 대여 여부
  status           String     @default("APPROVED") // APPROVED | WAITLISTED | CANCELLED
  waitlistPosition Int?
  cancelledAt      DateTime?
  isPenalized      Boolean    @default(false) // 취소 시 패널티 적용 여부
  submittedAt      DateTime   @default(now())
  foodOrderItems   ParticipantFoodOrderItem[]
  foodOrders       ParticipantFoodOrder[]
  chargeAdjustments ParticipantChargeAdjustment[]

  @@unique([meetingId, kakaoId, companionId])
}

model ParticipantChargeAdjustment {
  id            Int         @id @default(autoincrement())
  meetingId     Int
  participantId Int
  label         String
  amount        Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  meeting       Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model FoodMenuItem {
  id           Int                        @id @default(autoincrement())
  categoryId   Int
  category     FoodMenuCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name         String
  price        Int
  isActive     Boolean                    @default(true)
  displayOrder Int                        @default(0)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  orderItems   ParticipantFoodOrderItem[]
}

model FoodMenuCategory {
  id           Int            @id @default(autoincrement())
  name         String
  displayOrder Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  menuItems    FoodMenuItem[]
}

model ParticipantFoodOrder {
  id            Int                        @id @default(autoincrement())
  meetingId     Int
  participantId Int
  createdAt     DateTime                   @default(now())
  meeting       Meeting                    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participant   Participant                @relation(fields: [participantId], references: [id], onDelete: Cascade)
  items         ParticipantFoodOrderItem[]

  @@index([meetingId, participantId])
}

model ParticipantFoodOrderItem {
  id                Int                  @id @default(autoincrement())
  meetingId         Int
  participantId     Int
  foodOrderId       Int
  menuItemId        Int
  menuNameSnapshot  String
  unitPriceSnapshot Int
  quantity          Int
  preparingQuantity Int                  @default(0)
  servedQuantity    Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  meeting           Meeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participant       Participant          @relation(fields: [participantId], references: [id], onDelete: Cascade)
  menuItem          FoodMenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  foodOrder         ParticipantFoodOrder @relation(fields: [foodOrderId], references: [id], onDelete: Cascade)

  @@index([meetingId, participantId])
  @@index([foodOrderId])
}

model SettlementConfirmation {
  id              Int      @id @default(autoincrement())
  meetingId       Int
  recipientKakaoId String
  confirmedAt     DateTime @default(now())
  meeting         Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, recipientKakaoId])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int           @id @default(autoincrement())
  kakaoId      String        @unique
  name         String?       // 카카오 또는 유저가 정한 이름
  profileImage String?
  customProfileImageUrl String?
  phoneNumber  String?
  role         String        @default("MEMBER")   // ADMIN, SHOP_OWNER, MEMBER, BANNED
  memberType   String        @default("REGULAR")  // REGULAR | COMPANION
  penaltyCount Int           @default(0)          // 누적 패널티 횟수
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  participants Participant[]
  companions   Companion[]   // 내가 등록한 동반인 목록
}

model Companion {
  id             Int           @id @default(autoincrement())
  name           String
  ownerKakaoId   String        // 등록한 정회원의 kakaoId
  owner          User          @relation(fields: [ownerKakaoId], references: [kakaoId])
  linkedKakaoId  String?       // 카카오 로그인으로 연동된 동반인의 kakaoId
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  participants   Participant[]
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model DeletedKakaoId {
  id        Int      @id @default(autoincrement())
  kakaoId   String   @unique
  deletedAt DateTime @default(now())
}
